<Window x:Class="lifeviz.OfflineRenderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Render Fixed Duration"
        Width="500"
        Height="350"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#171717"
        Foreground="#F2F2F2"
        Closing="Window_Closing">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock FontSize="18" FontWeight="SemiBold" Text="Offline video render" />
        <TextBlock Grid.Row="1" Margin="0,8,0,14" Foreground="#BDBDBD" TextWrapping="Wrap"
                   Text="Enter the finished video duration. LifeViz will render every frame as fast as the machine and encoder allow. Unmuted video tracks drive audio reactivity; the output video remains silent." />

        <StackPanel x:Name="DurationPanel" Grid.Row="2" Orientation="Horizontal">
            <TextBlock VerticalAlignment="Center" Margin="0,0,10,0" Text="Duration (H:MM:SS)" />
            <TextBox x:Name="DurationTextBox" Width="105" Padding="6,4" Text="5:00:00" />
            <TextBlock VerticalAlignment="Center" Margin="22,0,10,0" Text="Output FPS" />
            <ComboBox x:Name="OutputFpsComboBox" Width="130" Padding="5,3" />
        </StackPanel>

        <TextBlock x:Name="ValidationText" Grid.Row="3" Margin="0,7,0,0" Foreground="#FF7777" Visibility="Collapsed" />

        <StackPanel x:Name="ProgressPanel" Grid.Row="4" Margin="0,16,0,0" Visibility="Collapsed">
            <ProgressBar x:Name="RenderProgressBar" Height="18" Minimum="0" Maximum="1" />
            <TextBlock x:Name="ProgressText" Margin="0,8,0,0" Text="Preparing render..." />
            <TextBlock x:Name="EtaText" Margin="0,3,0,0" Foreground="#BDBDBD" />
        </StackPanel>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="CloseButton" Content="Close" Width="88" Margin="0,0,8,0" IsCancel="True" />
            <Button x:Name="CancelRenderButton" Content="Cancel Render" Width="105" Margin="0,0,8,0"
                    Visibility="Collapsed" Click="CancelRenderButton_Click" />
            <Button x:Name="StartButton" Content="Start Render" Width="105" IsDefault="True" Click="StartButton_Click" />
        </StackPanel>
    </Grid>
</Window>
