<Window x:Class="lifeviz.LayerEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Scene Editor"
        Width="1240"
        Height="860"
        MinWidth="980"
        MinHeight="620"
        Background="#0B0B0B"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F5F5F5" />
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#F5F5F5" />
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="#F5F5F5" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#F5F5F5" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#262626" />
            <Setter Property="BorderBrush" Value="#3A3A3A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#F2F2F2" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="Margin" Value="0,0,6,6" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1A1A1A" />
            <Setter Property="BorderBrush" Value="#3A3A3A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#F2F2F2" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#F2F2F2" />
            <Setter Property="BorderBrush" Value="#BFBFBF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#000000" />
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="#000000" />
        </Style>

        <HierarchicalDataTemplate x:Key="SourceTreeTemplate" ItemsSource="{Binding Children}">
            <Border Margin="0,1,0,1"
                    Padding="4"
                    Background="Transparent"
                    CornerRadius="3">
                <StackPanel>
                    <DockPanel LastChildFill="False">
                        <TextBlock Text="{Binding TreeLabel}"
                                   FontWeight="SemiBold"
                                   DockPanel.Dock="Left" />
                        <TextBlock Text="{Binding KindLabel}"
                                   Foreground="#9EA4AE"
                                   FontSize="11"
                                   DockPanel.Dock="Right" />
                    </DockPanel>
                    <TextBlock Text="{Binding Details}"
                               Foreground="#8E8E8E"
                               FontSize="11"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,2,0,0" />
                </StackPanel>
            </Border>
        </HierarchicalDataTemplate>

        <DataTemplate x:Key="SimulationLayerTemplate">
            <Border Margin="0,1,0,1"
                    Padding="4"
                    Background="Transparent"
                    CornerRadius="3">
                <StackPanel>
                    <TextBlock Text="{Binding TreeLabel}"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{Binding Details}"
                               Foreground="#8E8E8E"
                               FontSize="11"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,2,0,0" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <Style TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
            <Setter Property="Foreground" Value="#F2F2F2" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <DataTemplate x:Key="AnimationTemplate">
            <Border BorderBrush="#2A2A2A"
                    BorderThickness="1"
                    Padding="8"
                    Margin="0,0,0,8"
                    Background="#141414"
                    CornerRadius="4">
                <StackPanel>
                    <DockPanel>
                        <TextBlock Text="{Binding DisplayName}"
                                   FontWeight="Bold"
                                   DockPanel.Dock="Left" />
                        <Button Content="Remove"
                                DockPanel.Dock="Right"
                                Padding="8,2"
                                Margin="8,0,0,0"
                                Click="RemoveAnimation_Click" />
                    </DockPanel>

                    <WrapPanel Margin="0,6,0,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,12,6">
                            <TextBlock Text="Loop" VerticalAlignment="Center" />
                            <ComboBox ItemsSource="{Binding LoopOptions}"
                                      DisplayMemberPath="Label"
                                      SelectedValuePath="Value"
                                      SelectedValue="{Binding Loop}"
                                      Margin="6,0,0,0"
                                      Width="140"
                                      SelectionChanged="AnimationLoop_Changed" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,12,6">
                            <TextBlock Text="Speed" VerticalAlignment="Center" />
                            <ComboBox ItemsSource="{Binding SpeedOptions}"
                                      DisplayMemberPath="Label"
                                      SelectedValuePath="Value"
                                      SelectedValue="{Binding Speed}"
                                      Margin="6,0,0,0"
                                      Width="120"
                                      SelectionChanged="AnimationSpeed_Changed" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,12,6">
                            <TextBlock Text="Cycle" VerticalAlignment="Center" />
                            <Slider Minimum="1"
                                    Maximum="{Binding CycleMax}"
                                    Value="{Binding BeatsPerCycle}"
                                    Width="160"
                                    SmallChange="1"
                                    LargeChange="{Binding CycleLargeChange}"
                                    Margin="6,0,0,0"
                                    ValueChanged="AnimationCycle_Changed" />
                            <TextBlock Text="{Binding BeatsPerCycle, StringFormat={}{0:0} beats}"
                                       Margin="6,0,0,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </WrapPanel>

                    <WrapPanel Margin="0,2,0,0">
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,0,12,6"
                                    Visibility="{Binding IsTranslate, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="Direction" VerticalAlignment="Center" />
                            <ComboBox ItemsSource="{Binding TranslateDirectionOptions}"
                                      DisplayMemberPath="Label"
                                      SelectedValuePath="Value"
                                      SelectedValue="{Binding TranslateDirection}"
                                      Margin="6,0,0,0"
                                      Width="140"
                                      SelectionChanged="AnimationTranslateDirection_Changed" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,0,12,6"
                                    Visibility="{Binding IsRotate, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="Direction" VerticalAlignment="Center" />
                            <ComboBox ItemsSource="{Binding RotationDirectionOptions}"
                                      DisplayMemberPath="Label"
                                      SelectedValuePath="Value"
                                      SelectedValue="{Binding RotationDirection}"
                                      Margin="6,0,0,0"
                                      Width="160"
                                      SelectionChanged="AnimationRotateDirection_Changed" />
                            <TextBlock Text="Angle"
                                       VerticalAlignment="Center"
                                       Margin="12,0,0,0" />
                            <Slider Minimum="0"
                                    Maximum="360"
                                    Value="{Binding RotationDegrees}"
                                    Width="120"
                                    SmallChange="1"
                                    LargeChange="15"
                                    Margin="6,0,0,0"
                                    ValueChanged="AnimationRotateDegrees_Changed" />
                            <TextBlock Text="{Binding RotationDegrees, StringFormat={}{0:0}°}"
                                       Margin="6,0,0,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,0,12,6"
                                    Visibility="{Binding IsDvd, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="Size" VerticalAlignment="Center" />
                            <Slider Minimum="0.05"
                                    Maximum="0.5"
                                    Value="{Binding DvdScale}"
                                    Width="160"
                                    SmallChange="0.01"
                                    LargeChange="0.05"
                                    Margin="6,0,0,0"
                                    ValueChanged="AnimationSize_Changed" />
                            <TextBlock Text="{Binding DvdScale, StringFormat={}{0:P0}}"
                                       Margin="6,0,0,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,0,12,6"
                                    Visibility="{Binding IsIntensityVisible, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="Intensity" VerticalAlignment="Center" />
                            <Slider Minimum="0"
                                    Maximum="{Binding IntensityMax}"
                                    Value="{Binding BeatShakeIntensity}"
                                    Width="160"
                                    SmallChange="0.05"
                                    LargeChange="{Binding IntensityLargeChange}"
                                    Margin="6,0,0,0"
                                    ValueChanged="AnimationBeatShakeIntensity_Changed" />
                            <TextBlock Text="{Binding BeatShakeIntensity, StringFormat={}{0:P0}}"
                                       Margin="6,0,0,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,0,12,6"
                                    Visibility="{Binding IsAudioGranularEqVisible, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="EQ Low" VerticalAlignment="Center" />
                            <Slider Minimum="0"
                                    Maximum="3"
                                    Value="{Binding AudioGranularLowGain}"
                                    Width="120"
                                    SmallChange="0.05"
                                    LargeChange="0.25"
                                    Margin="6,0,0,0"
                                    ValueChanged="AnimationAudioGranularLowEq_Changed" />
                            <TextBlock Text="{Binding AudioGranularLowGain, StringFormat={}{0:P0}}"
                                       Margin="6,0,10,0"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="Mid" VerticalAlignment="Center" />
                            <Slider Minimum="0"
                                    Maximum="3"
                                    Value="{Binding AudioGranularMidGain}"
                                    Width="120"
                                    SmallChange="0.05"
                                    LargeChange="0.25"
                                    Margin="6,0,0,0"
                                    ValueChanged="AnimationAudioGranularMidEq_Changed" />
                            <TextBlock Text="{Binding AudioGranularMidGain, StringFormat={}{0:P0}}"
                                       Margin="6,0,10,0"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="High" VerticalAlignment="Center" />
                            <Slider Minimum="0"
                                    Maximum="3"
                                    Value="{Binding AudioGranularHighGain}"
                                    Width="120"
                                    SmallChange="0.05"
                                    LargeChange="0.25"
                                    Margin="6,0,0,0"
                                    ValueChanged="AnimationAudioGranularHighEq_Changed" />
                            <TextBlock Text="{Binding AudioGranularHighGain, StringFormat={}{0:P0}}"
                                       Margin="6,0,0,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="12"
          TextElement.Foreground="#FFFFFF">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,10">
            <TextBlock Text="Scene Editor"
                       FontSize="20"
                       FontWeight="Bold"
                       DockPanel.Dock="Left"
                       VerticalAlignment="Center" />
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                <CheckBox Content="Master Audio"
                          IsChecked="{Binding SourceAudioMasterEnabled}"
                          Margin="0,0,8,0"
                          VerticalAlignment="Center"
                          Checked="MasterVideoAudio_Changed"
                          Unchecked="MasterVideoAudio_Changed" />
                <Slider Minimum="0"
                        Maximum="1"
                        Value="{Binding SourceAudioMasterVolume}"
                        Width="120"
                        SmallChange="0.05"
                        LargeChange="0.1"
                        Margin="0,0,6,0"
                        VerticalAlignment="Center"
                        ValueChanged="MasterVideoAudioVolume_Changed" />
                <TextBlock Text="{Binding SourceAudioMasterVolume, StringFormat={}{0:P0}}"
                           Margin="0,0,12,0"
                           VerticalAlignment="Center"
                           Foreground="#C8C8C8" />
                <CheckBox x:Name="LiveModeCheckBox"
                          Content="Live Mode"
                          IsChecked="{Binding LiveMode}"
                          Margin="0,0,12,0"
                          VerticalAlignment="Center"
                          Checked="LiveModeToggle"
                          Unchecked="LiveModeToggle" />
                <Button x:Name="AppControlsButton"
                        Content="App Controls..."
                        Click="OpenAppControls_Click" />
                <Button x:Name="LoadLayersButton"
                        Content="Load..."
                        Click="LoadLayerConfig_Click" />
                <Button x:Name="SaveLayersButton"
                        Content="Save..."
                        Click="SaveLayerConfig_Click" />
                <Button x:Name="ApplyButton"
                        Content="Apply"
                        Click="ApplyButton_Click" />
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="430" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    BorderBrush="#2E2E2E"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="10"
                    Background="#101010">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <WrapPanel Grid.Row="0" Margin="0,0,0,6">
                        <TextBlock Text="Add Root"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,6" />
                        <Button Content="Group" Click="AddRootGroup_Click" />
                        <Button Content="Window" Click="AddRootWindow_Click" />
                        <Button Content="Webcam" Click="AddRootWebcam_Click" />
                        <Button Content="File" Click="AddRootFile_Click" />
                        <Button Content="YouTube" Click="AddRootYoutube_Click" />
                        <Button Content="Sequence" Click="AddRootSequence_Click" />
                    </WrapPanel>

                    <WrapPanel Grid.Row="1" Margin="0,0,0,8">
                        <TextBlock Text="Add Child"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,6" />
                        <Button Content="Group" Click="AddChildGroup_Click" />
                        <Button Content="Window" Click="AddChildWindow_Click" />
                        <Button Content="Webcam" Click="AddChildWebcam_Click" />
                        <Button Content="File" Click="AddChildFile_Click" />
                        <Button Content="YouTube" Click="AddChildYoutube_Click" />
                        <Button Content="Sequence" Click="AddChildSequence_Click" />
                    </WrapPanel>

                    <Border Grid.Row="2"
                            BorderBrush="#2A2A2A"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="4"
                            Background="#141414"
                            AllowDrop="True"
                            DragOver="SceneTree_DragOver"
                            Drop="SceneTree_Drop">
                        <TreeView x:Name="SceneTree"
                                  ItemsSource="{Binding Sources}"
                                  ItemTemplate="{StaticResource SourceTreeTemplate}"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  SelectedItemChanged="SceneTree_SelectedItemChanged"
                                  PreviewMouseLeftButtonDown="SceneTree_PreviewMouseLeftButtonDown"
                                  PreviewMouseMove="SceneTree_PreviewMouseMove"
                                  AllowDrop="True" />
                    </Border>

                    <WrapPanel Grid.Row="3" Margin="0,8,0,0">
                        <Button Content="Make Primary"
                                Click="MakePrimary_Click" />
                        <Button Content="Move Up"
                                Click="MoveUp_Click" />
                        <Button Content="Move Down"
                                Click="MoveDown_Click" />
                        <Button Content="Remove"
                                Click="RemoveSource_Click" />
                        <Button Content="Restart"
                                Click="RestartVideo_Click" />
                        <Button Content="Clear Scene"
                                Click="ClearScene_Click" />
                    </WrapPanel>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    BorderBrush="#2E2E2E"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12"
                    Background="#101010">
                <Grid>
                    <TabControl Background="#101010"
                                BorderThickness="0"
                                Padding="0">
                        <TabItem Header="Selected Layer">
                            <StackPanel>
                        <TextBlock Text="Select a layer or group in the tree to edit its settings."
                                   Foreground="#A0A0A0"
                                   FontSize="14"
                                   Margin="0,0,0,8">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedSource}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel DataContext="{Binding SelectedSource}">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>

                                <Border BorderBrush="#2A2A2A"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="10"
                                        Margin="0,0,0,10"
                                        Background="#141414">
                                    <StackPanel>
                                        <DockPanel LastChildFill="False">
                                            <TextBlock Text="{Binding TreeLabel}"
                                                       FontSize="17"
                                                       FontWeight="Bold"
                                                       DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding KindLabel}"
                                                       Foreground="#9EA4AE"
                                                       FontSize="12"
                                                       DockPanel.Dock="Right" />
                                        </DockPanel>
                                        <TextBlock Text="{Binding Details}"
                                                   Foreground="#9A9A9A"
                                                   Margin="0,4,0,0" />
                                    </StackPanel>
                                </Border>

                                <GroupBox Header="Layer Settings">
                                    <StackPanel Margin="8">
                                        <WrapPanel Margin="0,0,0,4">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,12,6">
                                                <TextBlock Text="Blend"
                                                           VerticalAlignment="Center" />
                                                <ComboBox ItemsSource="{Binding BlendModeOptions}"
                                                          DisplayMemberPath="Label"
                                                          SelectedValuePath="Value"
                                                          SelectedValue="{Binding BlendMode}"
                                                          Margin="6,0,0,0"
                                                          Width="160"
                                                          SelectionChanged="BlendMode_Changed" />
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,12,6">
                                                <TextBlock Text="Fit"
                                                           VerticalAlignment="Center" />
                                                <ComboBox ItemsSource="{Binding FitModeOptions}"
                                                          DisplayMemberPath="Label"
                                                          SelectedValuePath="Value"
                                                          SelectedValue="{Binding FitMode}"
                                                          Margin="6,0,0,0"
                                                          Width="140"
                                                          SelectionChanged="FitMode_Changed" />
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,12,6">
                                                <TextBlock Text="Opacity"
                                                           VerticalAlignment="Center" />
                                                <Slider Minimum="0"
                                                        Maximum="1"
                                                        Value="{Binding Opacity}"
                                                        Width="150"
                                                        SmallChange="0.05"
                                                        LargeChange="0.1"
                                                        Margin="6,0,0,0"
                                                        ValueChanged="Opacity_Changed" />
                                                <TextBlock Text="{Binding Opacity, StringFormat={}{0:P0}}"
                                                           Margin="6,0,0,0"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                        </WrapPanel>

                                        <WrapPanel Margin="0,0,0,4">
                                            <CheckBox Content="Play Audio (Video/YouTube)"
                                                      Margin="0,0,12,6"
                                                      IsEnabled="{Binding IsVideo}"
                                                      IsChecked="{Binding VideoAudioEnabled}"
                                                      Checked="VideoAudio_Changed"
                                                      Unchecked="VideoAudio_Changed" />
                                            <StackPanel Orientation="Horizontal" Margin="0,0,12,6">
                                                <TextBlock Text="Audio Volume"
                                                           VerticalAlignment="Center"
                                                           Foreground="#D6D6D6" />
                                                <Slider Minimum="0"
                                                        Maximum="1"
                                                        Value="{Binding VideoAudioVolume}"
                                                        Width="130"
                                                        SmallChange="0.05"
                                                        LargeChange="0.1"
                                                        Margin="6,0,0,0"
                                                        IsEnabled="{Binding IsVideo}"
                                                        ValueChanged="VideoAudioVolume_Changed" />
                                                <TextBlock Text="{Binding VideoAudioVolume, StringFormat={}{0:P0}}"
                                                           Margin="6,0,0,0"
                                                           VerticalAlignment="Center"
                                                           Foreground="#C8C8C8" />
                                            </StackPanel>
                                            <Button Content="{Binding VideoPlaybackToggleLabel}"
                                                    Padding="8,2"
                                                    Margin="0,0,8,6"
                                                    IsEnabled="{Binding IsVideo}"
                                                    Click="VideoPlayPause_Click" />
                                            <StackPanel Orientation="Horizontal" Margin="0,0,12,6">
                                                <TextBlock Text="Scrub"
                                                           VerticalAlignment="Center"
                                                           Foreground="#D6D6D6" />
                                                <Slider Minimum="0"
                                                        Maximum="1"
                                                        Value="{Binding VideoPlaybackPosition}"
                                                        Width="160"
                                                        SmallChange="0.01"
                                                        LargeChange="0.05"
                                                        Margin="6,0,0,0"
                                                        IsEnabled="{Binding VideoSeekAvailable}"
                                                        IsMoveToPointEnabled="True"
                                                        PreviewMouseLeftButtonUp="VideoSeek_PreviewMouseLeftButtonUp" />
                                                <TextBlock Text="{Binding VideoPlaybackTimeLabel}"
                                                           Margin="6,0,0,0"
                                                           VerticalAlignment="Center"
                                                           Foreground="#C8C8C8" />
                                            </StackPanel>
                                            <CheckBox Content="Mirror Webcam"
                                                      Margin="0,0,12,6"
                                                      IsEnabled="{Binding IsWebcam}"
                                                      IsChecked="{Binding Mirror}"
                                                      Checked="Mirror_Changed"
                                                      Unchecked="Mirror_Changed" />
                                            <TextBlock Text="Group Name"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,8,6"
                                                       Visibility="{Binding IsGroup, Converter={StaticResource BoolToVisibility}}" />
                                            <TextBox Text="{Binding DisplayName}"
                                                     Width="240"
                                                     Margin="0,0,0,6"
                                                     TextChanged="GroupName_Changed"
                                                     Visibility="{Binding IsGroup, Converter={StaticResource BoolToVisibility}}" />
                                        </WrapPanel>

                                        <WrapPanel Margin="0,0,0,0"
                                                  IsEnabled="{Binding IsNormalBlend}">
                                            <CheckBox Content="Enable Keying (Normal)"
                                                      Margin="0,0,12,6"
                                                      IsChecked="{Binding KeyEnabled}"
                                                      Checked="KeyEnabled_Changed"
                                                      Unchecked="KeyEnabled_Changed" />
                                            <StackPanel Orientation="Horizontal" Margin="0,0,12,6">
                                                <TextBlock Text="Key Color"
                                                           VerticalAlignment="Center" />
                                                <TextBox Text="{Binding KeyColorHex}"
                                                         Width="90"
                                                         Margin="6,0,0,0"
                                                         LostFocus="KeyColorHex_LostFocus" />
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,12,6">
                                                <TextBlock Text="Key Range"
                                                           VerticalAlignment="Center" />
                                                <Slider Minimum="0"
                                                        Maximum="1"
                                                        Value="{Binding KeyTolerance}"
                                                        Width="140"
                                                        SmallChange="0.01"
                                                        LargeChange="0.05"
                                                        Margin="6,0,0,0"
                                                        ValueChanged="KeyTolerance_Changed" />
                                                <TextBlock Text="{Binding KeyTolerance, StringFormat={}{0:P0}}"
                                                           Margin="6,0,0,0"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                        </WrapPanel>
                                    </StackPanel>
                                </GroupBox>

                                <GroupBox Header="Animations">
                                    <StackPanel Margin="8">
                                        <ItemsControl ItemsSource="{Binding Animations}"
                                                      ItemTemplate="{StaticResource AnimationTemplate}" />

                                        <WrapPanel Margin="0,2,0,0">
                                            <TextBlock Text="Add"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,8,6" />
                                            <Button Content="Zoom"
                                                    Padding="8,2"
                                                    Margin="0,0,6,6"
                                                    Click="AddZoom_Click" />
                                            <ComboBox ItemsSource="{Binding TranslateDirectionOptions}"
                                                      DisplayMemberPath="Label"
                                                      SelectedValuePath="Value"
                                                      SelectedValue="{Binding PendingTranslateDirection}"
                                                      Width="110"
                                                      Margin="0,0,6,6" />
                                            <Button Content="Translate"
                                                    Padding="8,2"
                                                    Margin="0,0,12,6"
                                                    Click="AddTranslate_Click" />
                                            <ComboBox ItemsSource="{Binding RotationDirectionOptions}"
                                                      DisplayMemberPath="Label"
                                                      SelectedValuePath="Value"
                                                      SelectedValue="{Binding PendingRotationDirection}"
                                                      Width="140"
                                                      Margin="0,0,6,6" />
                                            <Button Content="Rotate"
                                                    Padding="8,2"
                                                    Margin="0,0,12,6"
                                                    Click="AddRotate_Click" />
                                            <Button Content="DVD"
                                                    Padding="8,2"
                                                    Margin="0,0,6,6"
                                                    Click="AddDvd_Click" />
                                            <Button Content="Beat Shake"
                                                    Padding="8,2"
                                                    Margin="0,0,6,6"
                                                    Click="AddBeatShake_Click" />
                                            <Button Content="Audio Granular"
                                                    Padding="8,2"
                                                    Margin="0,0,6,6"
                                                    Click="AddAudioGranular_Click" />
                                            <Button Content="Fade"
                                                    Padding="8,2"
                                                    Margin="0,0,0,6"
                                                    Click="AddFade_Click" />
                                        </WrapPanel>
                                    </StackPanel>
                                </GroupBox>
                            </StackPanel>
                        </ScrollViewer>
                            </StackPanel>
                        </TabItem>
                        <TabItem Header="Simulation Layers">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="10">
                                    <TextBlock Text="Each simulation layer injects from the final composite frame, runs its own Game of Life state, then blends over previous simulation layers."
                                               Foreground="#A0A0A0"
                                               Margin="0,0,0,10" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="3*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <WrapPanel Margin="0,0,0,8">
                                                <Button Content="Add Direct Layer"
                                                        Click="AddSimulationLayerDirect_Click" />
                                                <Button Content="Add Inverse Layer"
                                                        Click="AddSimulationLayerInverse_Click" />
                                            </WrapPanel>

                                            <Border BorderBrush="#2A2A2A"
                                                    BorderThickness="1"
                                                    CornerRadius="4"
                                                    Padding="4"
                                                    Background="#141414">
                                                <TreeView x:Name="SimulationLayerTree"
                                                          ItemsSource="{Binding SimulationLayers}"
                                                          ItemTemplate="{StaticResource SimulationLayerTemplate}"
                                                          Background="Transparent"
                                                          BorderThickness="0"
                                                          SelectedItemChanged="SimulationLayerTree_SelectedItemChanged" />
                                            </Border>

                                            <WrapPanel Margin="0,8,0,0">
                                                <Button Content="Move Up"
                                                        Click="MoveSimulationLayerUp_Click" />
                                                <Button Content="Move Down"
                                                        Click="MoveSimulationLayerDown_Click" />
                                                <Button Content="Remove"
                                                        Click="RemoveSimulationLayer_Click" />
                                            </WrapPanel>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2"
                                                    DataContext="{Binding SelectedSimulationLayer}">
                                            <TextBlock Text="Select a simulation layer to edit settings."
                                                       Foreground="#A0A0A0"
                                                       Margin="0,0,0,8">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <GroupBox Header="Layer Settings">
                                                <StackPanel Margin="8">
                                                    <StackPanel.Style>
                                                        <Style TargetType="StackPanel">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </StackPanel.Style>

                                                    <TextBlock Text="Name" />
                                                    <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                             Margin="0,4,0,8"
                                                             TextChanged="SimulationLayerName_Changed" />

                                                    <CheckBox Content="Enabled"
                                                              IsChecked="{Binding Enabled}"
                                                              Margin="0,0,0,8"
                                                              Checked="SimulationLayerEnabled_Changed"
                                                              Unchecked="SimulationLayerEnabled_Changed" />

                                                    <StackPanel Orientation="Horizontal"
                                                                Margin="0,0,0,8">
                                                        <TextBlock Text="Input"
                                                                   VerticalAlignment="Center" />
                                                        <ComboBox ItemsSource="{Binding InputFunctionOptions}"
                                                                  DisplayMemberPath="Label"
                                                                  SelectedValuePath="Value"
                                                                  SelectedValue="{Binding InputFunction}"
                                                                  Margin="8,0,0,0"
                                                                  Width="180"
                                                                  SelectionChanged="SimulationLayerInputFunction_Changed" />
                                                    </StackPanel>

                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="Blend"
                                                                   VerticalAlignment="Center" />
                                                        <ComboBox ItemsSource="{Binding BlendModeOptions}"
                                                                  DisplayMemberPath="Label"
                                                                  SelectedValuePath="Value"
                                                                  SelectedValue="{Binding BlendMode}"
                                                                  Margin="8,0,0,0"
                                                                  Width="180"
                                                                  SelectionChanged="SimulationLayerBlendMode_Changed" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </GroupBox>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
