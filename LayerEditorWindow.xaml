<Window x:Class="lifeviz.LayerEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Scene Editor"
        Width="1240"
        Height="860"
        MinWidth="980"
        MinHeight="620"
        Background="#0B0B0B"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F5F5F5" />
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#F5F5F5" />
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="#F5F5F5" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#F5F5F5" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#262626" />
            <Setter Property="BorderBrush" Value="#3A3A3A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#F2F2F2" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="Margin" Value="0,0,6,6" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1A1A1A" />
            <Setter Property="BorderBrush" Value="#3A3A3A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#F2F2F2" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#1A1A1A" />
            <Setter Property="BorderBrush" Value="#3A3A3A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#F2F2F2" />
            <Setter Property="Padding" Value="4,2" />
            <Setter Property="TextElement.Foreground" Value="#F2F2F2" />
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#1A1A1A" />
                        <Setter Property="Foreground" Value="#F2F2F2" />
                        <Setter Property="Padding" Value="6,3" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="ItemBorder"
                                            Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}"
                                            SnapsToDevicePixels="True"
                                            TextElement.Foreground="{TemplateBinding Foreground}">
                                        <ContentPresenter HorizontalAlignment="Stretch"
                                                          VerticalAlignment="Center"
                                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                                    </Border>

                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="#2A2A2A" />
                                            <Setter Property="Foreground" Value="#F5F5F5" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="#343434" />
                                            <Setter Property="Foreground" Value="#FFFFFF" />
                                        </Trigger>
                                        <MultiTrigger>
                                            <MultiTrigger.Conditions>
                                                <Condition Property="IsSelected" Value="True" />
                                                <Condition Property="IsHighlighted" Value="True" />
                                            </MultiTrigger.Conditions>
                                            <Setter TargetName="ItemBorder" Property="Background" Value="#404040" />
                                            <Setter Property="Foreground" Value="#FFFFFF" />
                                        </MultiTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="ComboBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="2">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="26" />
                                    </Grid.ColumnDefinitions>

                                    <ContentPresenter Grid.Column="0"
                                                      Margin="8,2,4,2"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Left"
                                                    RecognizesAccessKey="True"
                                                    Content="{TemplateBinding SelectionBoxItem}"
                                                    ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                    ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                                    SnapsToDevicePixels="True"
                                                    TextElement.Foreground="{TemplateBinding Foreground}" />

                                    <ToggleButton Grid.Column="1"
                                                  Focusable="False"
                                                  Background="Transparent"
                                                  BorderBrush="{x:Null}"
                                                  ClickMode="Press"
                                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                        <Path HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Data="M 0 0 L 4 4 L 8 0 Z"
                                              Fill="{TemplateBinding Foreground}" />
                                    </ToggleButton>
                                </Grid>
                            </Border>

                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Slide">
                                <Border Margin="0,2,0,0"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        Background="#141414"
                                        BorderBrush="#3A3A3A"
                                        BorderThickness="1"
                                        CornerRadius="2">
                                    <ScrollViewer CanContentScroll="True">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ComboBorder" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#1A1A1A" />
            <Setter Property="Foreground" Value="#F2F2F2" />
            <Setter Property="Padding" Value="4,2" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#2A2A2A" />
                                <Setter Property="Foreground" Value="#F5F5F5" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#343434" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <HierarchicalDataTemplate x:Key="SourceTreeTemplate" ItemsSource="{Binding Children}">
            <Border Margin="0,1,0,1"
                    Padding="4"
                    Background="Transparent"
                    CornerRadius="3">
                <StackPanel>
                    <DockPanel LastChildFill="False">
                        <TextBlock Text="{Binding TreeLabel}"
                                   FontWeight="SemiBold"
                                   DockPanel.Dock="Left" />
                        <TextBlock Text="{Binding KindLabel}"
                                   Foreground="#9EA4AE"
                                   FontSize="11"
                                   DockPanel.Dock="Right" />
                    </DockPanel>
                    <TextBlock Text="{Binding Details}"
                               Foreground="#8E8E8E"
                               FontSize="11"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,2,0,0" />
                </StackPanel>
            </Border>
        </HierarchicalDataTemplate>

        <HierarchicalDataTemplate x:Key="SimulationLayerTemplate" ItemsSource="{Binding Children}">
            <Border Margin="0,1,0,1"
                    Padding="4"
                    Background="Transparent"
                    CornerRadius="3">
                <StackPanel>
                    <DockPanel LastChildFill="False">
                        <TextBlock Text="{Binding TreeLabel}"
                                   FontWeight="SemiBold"
                                   DockPanel.Dock="Left" />
                        <TextBlock Text="{Binding KindLabel}"
                                   Foreground="#9EA4AE"
                                   FontSize="11"
                                   DockPanel.Dock="Right" />
                    </DockPanel>
                    <TextBlock Text="{Binding Details}"
                               Foreground="#8E8E8E"
                               FontSize="11"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,2,0,0" />
                </StackPanel>
            </Border>
        </HierarchicalDataTemplate>

        <Style x:Key="SourceTreeViewItemStyle" TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
            <Setter Property="Foreground" Value="#F2F2F2" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style x:Key="SimulationTreeViewItemStyle" TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
            <Setter Property="Foreground" Value="#F2F2F2" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <DataTemplate x:Key="AnimationTemplate">
            <Border BorderBrush="#2A2A2A"
                    BorderThickness="1"
                    Padding="8"
                    Margin="0,0,0,8"
                    Background="#141414"
                    CornerRadius="4">
                <StackPanel>
                    <DockPanel>
                        <TextBlock Text="{Binding DisplayName}"
                                   FontWeight="Bold"
                                   DockPanel.Dock="Left" />
                        <Button Content="Remove"
                                DockPanel.Dock="Right"
                                Padding="8,2"
                                Margin="8,0,0,0"
                                Click="RemoveAnimation_Click" />
                    </DockPanel>

                    <WrapPanel Margin="0,6,0,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,12,6">
                            <TextBlock Text="Loop" VerticalAlignment="Center" />
                            <ComboBox ItemsSource="{Binding LoopOptions}"
                                      DisplayMemberPath="Label"
                                      SelectedValuePath="Value"
                                      SelectedValue="{Binding Loop}"
                                      Margin="6,0,0,0"
                                      Width="140"
                                      SelectionChanged="AnimationLoop_Changed" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,12,6">
                            <TextBlock Text="Speed" VerticalAlignment="Center" />
                            <ComboBox ItemsSource="{Binding SpeedOptions}"
                                      DisplayMemberPath="Label"
                                      SelectedValuePath="Value"
                                      SelectedValue="{Binding Speed}"
                                      Margin="6,0,0,0"
                                      Width="120"
                                      SelectionChanged="AnimationSpeed_Changed" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,12,6">
                            <TextBlock Text="Cycle" VerticalAlignment="Center" />
                            <Slider Minimum="1"
                                    Maximum="{Binding CycleMax}"
                                    Value="{Binding BeatsPerCycle}"
                                    Width="160"
                                    SmallChange="1"
                                    LargeChange="{Binding CycleLargeChange}"
                                    Margin="6,0,0,0"
                                    ValueChanged="AnimationCycle_Changed" />
                            <TextBlock Text="{Binding BeatsPerCycle, StringFormat={}{0:0} beats}"
                                       Margin="6,0,0,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </WrapPanel>

                    <WrapPanel Margin="0,2,0,0">
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,0,12,6"
                                    Visibility="{Binding IsTranslate, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="Direction" VerticalAlignment="Center" />
                            <ComboBox ItemsSource="{Binding TranslateDirectionOptions}"
                                      DisplayMemberPath="Label"
                                      SelectedValuePath="Value"
                                      SelectedValue="{Binding TranslateDirection}"
                                      Margin="6,0,0,0"
                                      Width="140"
                                      SelectionChanged="AnimationTranslateDirection_Changed" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,0,12,6"
                                    Visibility="{Binding IsRotate, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="Direction" VerticalAlignment="Center" />
                            <ComboBox ItemsSource="{Binding RotationDirectionOptions}"
                                      DisplayMemberPath="Label"
                                      SelectedValuePath="Value"
                                      SelectedValue="{Binding RotationDirection}"
                                      Margin="6,0,0,0"
                                      Width="160"
                                      SelectionChanged="AnimationRotateDirection_Changed" />
                            <TextBlock Text="Angle"
                                       VerticalAlignment="Center"
                                       Margin="12,0,0,0" />
                            <Slider Minimum="0"
                                    Maximum="360"
                                    Value="{Binding RotationDegrees}"
                                    Width="120"
                                    SmallChange="1"
                                    LargeChange="15"
                                    Margin="6,0,0,0"
                                    ValueChanged="AnimationRotateDegrees_Changed" />
                            <TextBlock Text="{Binding RotationDegrees, StringFormat={}{0:0}°}"
                                       Margin="6,0,0,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,0,12,6"
                                    Visibility="{Binding IsDvd, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="Size" VerticalAlignment="Center" />
                            <Slider Minimum="0.05"
                                    Maximum="0.5"
                                    Value="{Binding DvdScale}"
                                    Width="160"
                                    SmallChange="0.01"
                                    LargeChange="0.05"
                                    Margin="6,0,0,0"
                                    ValueChanged="AnimationSize_Changed" />
                            <TextBlock Text="{Binding DvdScale, StringFormat={}{0:P0}}"
                                       Margin="6,0,0,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,0,12,6"
                                    Visibility="{Binding IsIntensityVisible, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="Intensity" VerticalAlignment="Center" />
                            <Slider Minimum="0"
                                    Maximum="{Binding IntensityMax}"
                                    Value="{Binding BeatShakeIntensity}"
                                    Width="160"
                                    SmallChange="0.05"
                                    LargeChange="{Binding IntensityLargeChange}"
                                    Margin="6,0,0,0"
                                    ValueChanged="AnimationBeatShakeIntensity_Changed" />
                            <TextBlock Text="{Binding BeatShakeIntensity, StringFormat={}{0:P0}}"
                                       Margin="6,0,0,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,0,12,6"
                                    Visibility="{Binding IsAudioGranularEqVisible, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="EQ Low" VerticalAlignment="Center" />
                            <Slider Minimum="0"
                                    Maximum="3"
                                    Value="{Binding AudioGranularLowGain}"
                                    Width="120"
                                    SmallChange="0.05"
                                    LargeChange="0.25"
                                    Margin="6,0,0,0"
                                    ValueChanged="AnimationAudioGranularLowEq_Changed" />
                            <TextBlock Text="{Binding AudioGranularLowGain, StringFormat={}{0:P0}}"
                                       Margin="6,0,10,0"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="Mid" VerticalAlignment="Center" />
                            <Slider Minimum="0"
                                    Maximum="3"
                                    Value="{Binding AudioGranularMidGain}"
                                    Width="120"
                                    SmallChange="0.05"
                                    LargeChange="0.25"
                                    Margin="6,0,0,0"
                                    ValueChanged="AnimationAudioGranularMidEq_Changed" />
                            <TextBlock Text="{Binding AudioGranularMidGain, StringFormat={}{0:P0}}"
                                       Margin="6,0,10,0"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="High" VerticalAlignment="Center" />
                            <Slider Minimum="0"
                                    Maximum="3"
                                    Value="{Binding AudioGranularHighGain}"
                                    Width="120"
                                    SmallChange="0.05"
                                    LargeChange="0.25"
                                    Margin="6,0,0,0"
                                    ValueChanged="AnimationAudioGranularHighEq_Changed" />
                            <TextBlock Text="{Binding AudioGranularHighGain, StringFormat={}{0:P0}}"
                                       Margin="6,0,0,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="12"
          TextElement.Foreground="#FFFFFF">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,10">
            <TextBlock Text="Scene Editor"
                       FontSize="20"
                       FontWeight="Bold"
                       DockPanel.Dock="Left"
                       VerticalAlignment="Center" />
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                <CheckBox Content="Master Audio"
                          IsChecked="{Binding SourceAudioMasterEnabled}"
                          Margin="0,0,8,0"
                          VerticalAlignment="Center"
                          Checked="MasterVideoAudio_Changed"
                          Unchecked="MasterVideoAudio_Changed" />
                <Slider Minimum="0"
                        Maximum="1"
                        Value="{Binding SourceAudioMasterVolume}"
                        Width="120"
                        SmallChange="0.05"
                        LargeChange="0.1"
                        Margin="0,0,6,0"
                        VerticalAlignment="Center"
                        ValueChanged="MasterVideoAudioVolume_Changed" />
                <TextBlock Text="{Binding SourceAudioMasterVolume, StringFormat={}{0:P0}}"
                           Margin="0,0,12,0"
                           VerticalAlignment="Center"
                           Foreground="#C8C8C8" />
                <CheckBox x:Name="LiveModeCheckBox"
                          Content="Live Mode"
                          IsChecked="{Binding LiveMode}"
                          Margin="0,0,12,0"
                          VerticalAlignment="Center"
                          Checked="LiveModeToggle"
                          Unchecked="LiveModeToggle" />
                <Button x:Name="AppControlsButton"
                        Content="App Controls..."
                        Click="OpenAppControls_Click" />
                <Button x:Name="LoadLayersButton"
                        Content="Load..."
                        Click="LoadLayerConfig_Click" />
                <Button x:Name="SaveLayersButton"
                        Content="Save..."
                        Click="SaveLayerConfig_Click" />
                <Button x:Name="ApplyButton"
                        Content="Apply"
                        Click="ApplyButton_Click" />
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="430" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    BorderBrush="#2E2E2E"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="10"
                    Background="#101010">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <WrapPanel Grid.Row="0" Margin="0,0,0,6">
                        <TextBlock Text="Add Root"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,6" />
                        <Button Content="Group" Click="AddRootGroup_Click" />
                        <Button Content="Sim Group" Click="AddRootSimGroup_Click" />
                        <Button Content="Window" Click="AddRootWindow_Click" />
                        <Button Content="Webcam" Click="AddRootWebcam_Click" />
                        <Button Content="File" Click="AddRootFile_Click" />
                        <Button Content="YouTube" Click="AddRootYoutube_Click" />
                        <Button Content="Sequence" Click="AddRootSequence_Click" />
                    </WrapPanel>

                    <WrapPanel Grid.Row="1" Margin="0,0,0,8">
                        <TextBlock Text="Add Child"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,6" />
                        <Button Content="Group" Click="AddChildGroup_Click" />
                        <Button Content="Sim Group" Click="AddChildSimGroup_Click" />
                        <Button Content="Window" Click="AddChildWindow_Click" />
                        <Button Content="Webcam" Click="AddChildWebcam_Click" />
                        <Button Content="File" Click="AddChildFile_Click" />
                        <Button Content="YouTube" Click="AddChildYoutube_Click" />
                        <Button Content="Sequence" Click="AddChildSequence_Click" />
                    </WrapPanel>

                    <Border Grid.Row="2"
                            BorderBrush="#2A2A2A"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="4"
                            Background="#141414"
                            AllowDrop="True"
                            DragOver="SceneTree_DragOver"
                            Drop="SceneTree_Drop">
                        <TreeView x:Name="SceneTree"
                                  ItemsSource="{Binding Sources}"
                                  ItemTemplate="{StaticResource SourceTreeTemplate}"
                                  ItemContainerStyle="{StaticResource SourceTreeViewItemStyle}"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  SelectedItemChanged="SceneTree_SelectedItemChanged"
                                  PreviewMouseLeftButtonDown="SceneTree_PreviewMouseLeftButtonDown"
                                  PreviewMouseMove="SceneTree_PreviewMouseMove"
                                  AllowDrop="True" />
                    </Border>

                    <WrapPanel Grid.Row="3" Margin="0,8,0,0">
                        <Button Content="Make Primary"
                                Click="MakePrimary_Click" />
                        <Button Content="Move Up"
                                Click="MoveUp_Click" />
                        <Button Content="Move Down"
                                Click="MoveDown_Click" />
                        <Button x:Name="SceneRemoveSourceButton"
                                Content="Remove"
                                Click="RemoveSource_Click" />
                        <Button Content="Restart"
                                Click="RestartVideo_Click" />
                        <Button Content="Clear Scene"
                                Click="ClearScene_Click" />
                    </WrapPanel>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    BorderBrush="#2E2E2E"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12"
                    Background="#101010">
                <Grid>
                    <TabControl Background="#101010"
                                BorderThickness="0"
                                Padding="0">
                        <TabItem Header="Selected Layer">
                            <StackPanel>
                        <TextBlock Text="Select a layer or group in the tree to edit its settings."
                                   Foreground="#A0A0A0"
                                   FontSize="14"
                                   Margin="0,0,0,8">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedSource}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel DataContext="{Binding SelectedSource}">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>

                                <Border BorderBrush="#2A2A2A"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="10"
                                        Margin="0,0,0,10"
                                        Background="#141414">
                                    <StackPanel>
                                        <DockPanel LastChildFill="False">
                                            <TextBlock Text="{Binding TreeLabel}"
                                                       FontSize="17"
                                                       FontWeight="Bold"
                                                       DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding KindLabel}"
                                                       Foreground="#9EA4AE"
                                                       FontSize="12"
                                                       DockPanel.Dock="Right" />
                                        </DockPanel>
                                        <TextBlock Text="{Binding Details}"
                                                   Foreground="#9A9A9A"
                                                   Margin="0,4,0,0" />
                                    </StackPanel>
                                </Border>

                                <GroupBox Header="Layer Settings">
                                    <StackPanel Margin="8">
                                        <WrapPanel Margin="0,0,0,8"
                                                   Visibility="{Binding IsSimulationGroup, Converter={StaticResource BoolToVisibility}}">
                                            <CheckBox Content="Enabled"
                                                      Margin="0,0,12,6"
                                                      IsChecked="{Binding Enabled}"
                                                      Checked="SimulationGroupEnabled_Changed"
                                                      Unchecked="SimulationGroupEnabled_Changed" />
                                            <TextBlock Text="Group Name"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,8,6" />
                                            <TextBox Text="{Binding DisplayName}"
                                                     Width="240"
                                                     Margin="0,0,0,6"
                                                     TextChanged="GroupName_Changed" />
                                        </WrapPanel>

                                        <StackPanel>
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSimulationGroup}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>

                                        <WrapPanel Margin="0,0,0,4">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,12,6">
                                                <TextBlock Text="Blend"
                                                           VerticalAlignment="Center" />
                                                <ComboBox ItemsSource="{Binding BlendModeOptions}"
                                                          DisplayMemberPath="Label"
                                                          SelectedValuePath="Value"
                                                          SelectedValue="{Binding BlendMode}"
                                                          Margin="6,0,0,0"
                                                          Width="160"
                                                          SelectionChanged="BlendMode_Changed" />
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,12,6">
                                                <TextBlock Text="Fit"
                                                           VerticalAlignment="Center" />
                                                <ComboBox ItemsSource="{Binding FitModeOptions}"
                                                          DisplayMemberPath="Label"
                                                          SelectedValuePath="Value"
                                                          SelectedValue="{Binding FitMode}"
                                                          Margin="6,0,0,0"
                                                          Width="140"
                                                          SelectionChanged="FitMode_Changed" />
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,12,6">
                                                <TextBlock Text="Opacity"
                                                           VerticalAlignment="Center" />
                                                <Slider Minimum="0"
                                                        Maximum="1"
                                                        Value="{Binding Opacity}"
                                                        Width="150"
                                                        SmallChange="0.05"
                                                        LargeChange="0.1"
                                                        Margin="6,0,0,0"
                                                        ValueChanged="Opacity_Changed" />
                                                <TextBlock Text="{Binding Opacity, StringFormat={}{0:P0}}"
                                                           Margin="6,0,0,0"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                        </WrapPanel>

                                        <WrapPanel Margin="0,0,0,4">
                                            <CheckBox Content="Play Audio (Video/YouTube)"
                                                      Margin="0,0,12,6"
                                                      IsEnabled="{Binding IsVideo}"
                                                      IsChecked="{Binding VideoAudioEnabled}"
                                                      Checked="VideoAudio_Changed"
                                                      Unchecked="VideoAudio_Changed" />
                                            <StackPanel Orientation="Horizontal" Margin="0,0,12,6">
                                                <TextBlock Text="Audio Volume"
                                                           VerticalAlignment="Center"
                                                           Foreground="#D6D6D6" />
                                                <Slider Minimum="0"
                                                        Maximum="1"
                                                        Value="{Binding VideoAudioVolume}"
                                                        Width="130"
                                                        SmallChange="0.05"
                                                        LargeChange="0.1"
                                                        Margin="6,0,0,0"
                                                        IsEnabled="{Binding IsVideo}"
                                                        ValueChanged="VideoAudioVolume_Changed" />
                                                <TextBlock Text="{Binding VideoAudioVolume, StringFormat={}{0:P0}}"
                                                           Margin="6,0,0,0"
                                                           VerticalAlignment="Center"
                                                           Foreground="#C8C8C8" />
                                            </StackPanel>
                                            <Button Content="{Binding VideoPlaybackToggleLabel}"
                                                    Padding="8,2"
                                                    Margin="0,0,8,6"
                                                    IsEnabled="{Binding IsVideo}"
                                                    Click="VideoPlayPause_Click" />
                                            <StackPanel Orientation="Horizontal" Margin="0,0,12,6">
                                                <TextBlock Text="Scrub"
                                                           VerticalAlignment="Center"
                                                           Foreground="#D6D6D6" />
                                                <Slider Minimum="0"
                                                        Maximum="1"
                                                        Value="{Binding VideoPlaybackPosition}"
                                                        Width="160"
                                                        SmallChange="0.01"
                                                        LargeChange="0.05"
                                                        Margin="6,0,0,0"
                                                        IsEnabled="{Binding VideoSeekAvailable}"
                                                        IsMoveToPointEnabled="True"
                                                        PreviewMouseLeftButtonUp="VideoSeek_PreviewMouseLeftButtonUp" />
                                                <TextBlock Text="{Binding VideoPlaybackTimeLabel}"
                                                           Margin="6,0,0,0"
                                                           VerticalAlignment="Center"
                                                           Foreground="#C8C8C8" />
                                            </StackPanel>
                                            <CheckBox Content="Mirror Webcam"
                                                      Margin="0,0,12,6"
                                                      IsEnabled="{Binding IsWebcam}"
                                                      IsChecked="{Binding Mirror}"
                                                      Checked="Mirror_Changed"
                                                      Unchecked="Mirror_Changed" />
                                            <TextBlock Text="Group Name"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,8,6"
                                                       Visibility="{Binding IsContainerGroup, Converter={StaticResource BoolToVisibility}}" />
                                            <TextBox Text="{Binding DisplayName}"
                                                     Width="240"
                                                     Margin="0,0,0,6"
                                                     TextChanged="GroupName_Changed"
                                                     Visibility="{Binding IsContainerGroup, Converter={StaticResource BoolToVisibility}}" />
                                        </WrapPanel>

                                        <WrapPanel Margin="0,0,0,0"
                                                  IsEnabled="{Binding IsNormalBlend}">
                                            <CheckBox Content="Enable Keying (Normal)"
                                                      Margin="0,0,12,6"
                                                      IsChecked="{Binding KeyEnabled}"
                                                      Checked="KeyEnabled_Changed"
                                                      Unchecked="KeyEnabled_Changed" />
                                            <StackPanel Orientation="Horizontal" Margin="0,0,12,6">
                                                <TextBlock Text="Key Color"
                                                           VerticalAlignment="Center" />
                                                <TextBox Text="{Binding KeyColorHex}"
                                                         Width="90"
                                                         Margin="6,0,0,0"
                                                         LostFocus="KeyColorHex_LostFocus" />
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,12,6">
                                                <TextBlock Text="Key Range"
                                                           VerticalAlignment="Center" />
                                                <Slider Minimum="0"
                                                        Maximum="1"
                                                        Value="{Binding KeyTolerance}"
                                                        Width="140"
                                                        SmallChange="0.01"
                                                        LargeChange="0.05"
                                                        Margin="6,0,0,0"
                                                        ValueChanged="KeyTolerance_Changed" />
                                                <TextBlock Text="{Binding KeyTolerance, StringFormat={}{0:P0}}"
                                                           Margin="6,0,0,0"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                        </WrapPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </GroupBox>

                                <GroupBox Header="Animations">
                                    <GroupBox.Style>
                                        <Style TargetType="GroupBox">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSimulationGroup}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </GroupBox.Style>
                                    <StackPanel Margin="8">
                                        <ItemsControl ItemsSource="{Binding Animations}"
                                                      ItemTemplate="{StaticResource AnimationTemplate}" />

                                        <WrapPanel Margin="0,2,0,0">
                                            <TextBlock Text="Add"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,8,6" />
                                            <Button Content="Zoom"
                                                    Padding="8,2"
                                                    Margin="0,0,6,6"
                                                    Click="AddZoom_Click" />
                                            <ComboBox ItemsSource="{Binding TranslateDirectionOptions}"
                                                      DisplayMemberPath="Label"
                                                      SelectedValuePath="Value"
                                                      SelectedValue="{Binding PendingTranslateDirection}"
                                                      Width="110"
                                                      Margin="0,0,6,6" />
                                            <Button Content="Translate"
                                                    Padding="8,2"
                                                    Margin="0,0,12,6"
                                                    Click="AddTranslate_Click" />
                                            <ComboBox ItemsSource="{Binding RotationDirectionOptions}"
                                                      DisplayMemberPath="Label"
                                                      SelectedValuePath="Value"
                                                      SelectedValue="{Binding PendingRotationDirection}"
                                                      Width="140"
                                                      Margin="0,0,6,6" />
                                            <Button Content="Rotate"
                                                    Padding="8,2"
                                                    Margin="0,0,12,6"
                                                    Click="AddRotate_Click" />
                                            <Button Content="DVD"
                                                    Padding="8,2"
                                                    Margin="0,0,6,6"
                                                    Click="AddDvd_Click" />
                                            <Button Content="Beat Shake"
                                                    Padding="8,2"
                                                    Margin="0,0,6,6"
                                                    Click="AddBeatShake_Click" />
                                            <Button Content="Audio Granular"
                                                    Padding="8,2"
                                                    Margin="0,0,6,6"
                                                    Click="AddAudioGranular_Click" />
                                            <Button Content="Fade"
                                                    Padding="8,2"
                                                    Margin="0,0,0,6"
                                                    Click="AddFade_Click" />
                                        </WrapPanel>
                                    </StackPanel>
                                </GroupBox>

                                <GroupBox Header="Simulation Group">
                                    <GroupBox.Style>
                                        <Style TargetType="GroupBox">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSimulationGroup}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </GroupBox.Style>
                                    <StackPanel Margin="8">
                                        <TextBlock Text="Edit the simulation stack owned by this scene layer."
                                                   Foreground="#A0A0A0"
                                                   Margin="0,0,0,8" />
                                        <WrapPanel Margin="0,0,0,8">
                                            <Button Content="Add Life Sim"
                                                    Click="AddSimulationLayerDirect_Click" />
                                            <Button Content="Add Pixel Sort Layer"
                                                    Click="AddSimulationPixelSort_Click" />
                                            <Button Content="Move Up"
                                                    Click="MoveSimulationLayerUp_Click" />
                                            <Button Content="Move Down"
                                                    Click="MoveSimulationLayerDown_Click" />
                                            <Button Content="Remove"
                                                    Click="RemoveSimulationLayer_Click" />
                                        </WrapPanel>
                                        <Border BorderBrush="#2A2A2A"
                                                BorderThickness="1"
                                                CornerRadius="4"
                                                Padding="4"
                                                Background="#141414">
                                            <TreeView ItemsSource="{Binding SimulationLayers}"
                                                      ItemTemplate="{StaticResource SimulationLayerTemplate}"
                                                      ItemContainerStyle="{StaticResource SimulationTreeViewItemStyle}"
                                                      Background="Transparent"
                                                      BorderThickness="0"
                                                      SelectedItemChanged="SimulationLayerTree_SelectedItemChanged" />
                                        </Border>

                                        <StackPanel DataContext="{Binding SelectedSimulationLayer}"
                                                    Margin="0,10,0,0">
                                            <TextBlock Text="Select a simulation layer to edit settings."
                                                       Foreground="#A0A0A0"
                                                       Margin="0,0,0,8">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <GroupBox Header="Simulation Layer Settings">
                                                <StackPanel Margin="8">
                                                    <StackPanel.Style>
                                                        <Style TargetType="StackPanel">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </StackPanel.Style>

                                                    <TextBlock Text="Name" />
                                                    <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                             Margin="0,4,0,8"
                                                             TextChanged="SimulationLayerName_Changed" />

                                                    <TextBlock Text="Type" />
                                                    <TextBlock Text="{Binding TypeLabel}"
                                                               Foreground="#A0A0A0"
                                                               Margin="0,4,0,8" />

                                                    <CheckBox x:Name="SelectedSimulationEnabledCheckBox"
                                                              Content="Enabled"
                                                              IsChecked="{Binding Enabled}"
                                                              Margin="0,0,0,8"
                                                              Checked="SimulationLayerEnabled_Changed"
                                                              Unchecked="SimulationLayerEnabled_Changed" />

                                                    <TextBlock Text="Groups chain their children in order."
                                                               Foreground="#A0A0A0"
                                                               Margin="0,0,0,8"
                                                               Visibility="{Binding IsGroup, Converter={StaticResource BoolToVisibility}}" />

                                                    <StackPanel>
                                                        <StackPanel.Style>
                                                            <Style TargetType="StackPanel">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsGroup}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </StackPanel.Style>

                                                        <WrapPanel>
                                                            <StackPanel Orientation="Horizontal" Margin="0,0,12,6">
                                                                <TextBlock Text="Blend" VerticalAlignment="Center" />
                                                                <ComboBox ItemsSource="{Binding BlendModeOptions}"
                                                                          DisplayMemberPath="Label"
                                                                          SelectedValuePath="Value"
                                                                          SelectedValue="{Binding BlendMode}"
                                                                          Margin="8,0,0,0"
                                                                          Width="180"
                                                                          SelectionChanged="SimulationLayerBlendMode_Changed" />
                                                            </StackPanel>
                                                        </WrapPanel>

                                                        <WrapPanel>
                                                            <StackPanel Orientation="Horizontal" Margin="0,0,12,6">
                                                                <TextBlock Text="Opacity" VerticalAlignment="Center" />
                                                                <Slider Minimum="0"
                                                                        Maximum="1"
                                                                        Value="{Binding LifeOpacity}"
                                                                        Width="150"
                                                                        Margin="8,0,0,0"
                                                                        ValueChanged="SimulationLayerLifeOpacity_Changed" />
                                                            </StackPanel>
                                                        </WrapPanel>

                                                        <WrapPanel>
                                                            <StackPanel Orientation="Horizontal" Margin="0,0,12,6">
                                                                <TextBlock Text="Hue Offset" VerticalAlignment="Center" />
                                                                <Slider Minimum="0"
                                                                        Maximum="360"
                                                                        Value="{Binding RgbHueShiftDegrees}"
                                                                        Width="150"
                                                                        Margin="8,0,0,0"
                                                                        ValueChanged="SimulationLayerHue_Changed" />
                                                            </StackPanel>
                                                            <StackPanel Orientation="Horizontal" Margin="0,0,12,6">
                                                                <TextBlock Text="Hue Speed" VerticalAlignment="Center" />
                                                                <Slider Minimum="-180"
                                                                        Maximum="180"
                                                                        Value="{Binding RgbHueShiftSpeedDegreesPerSecond}"
                                                                        Width="150"
                                                                        Margin="8,0,0,0"
                                                                        ValueChanged="SimulationLayerHue_Changed" />
                                                            </StackPanel>
                                                        </WrapPanel>

                                                        <StackPanel>
                                                            <StackPanel.Style>
                                                                <Style TargetType="StackPanel">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsLifeLayer}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </StackPanel.Style>

                                                            <WrapPanel>
                                                                <StackPanel Orientation="Horizontal" Margin="0,0,12,6">
                                                                    <TextBlock Text="Input" VerticalAlignment="Center" />
                                                                    <ComboBox ItemsSource="{Binding InputFunctionOptions}"
                                                                              DisplayMemberPath="Label"
                                                                              SelectedValuePath="Value"
                                                                              SelectedValue="{Binding InputFunction}"
                                                                              Margin="8,0,0,0"
                                                                              Width="180"
                                                                              SelectionChanged="SimulationLayerInputFunction_Changed" />
                                                                </StackPanel>
                                                                <StackPanel Orientation="Horizontal" Margin="0,0,12,6">
                                                                    <TextBlock Text="Injection" VerticalAlignment="Center" />
                                                                    <ComboBox ItemsSource="{Binding InjectionModeOptions}"
                                                                              DisplayMemberPath="Label"
                                                                              SelectedValuePath="Value"
                                                                              SelectedValue="{Binding InjectionMode}"
                                                                              Margin="8,0,0,0"
                                                                              Width="180"
                                                                              SelectionChanged="SimulationLayerInjectionMode_Changed" />
                                                                </StackPanel>
                                                            </WrapPanel>

                                                            <WrapPanel>
                                                                <StackPanel Orientation="Horizontal" Margin="0,0,12,6">
                                                                    <TextBlock Text="Life Mode" VerticalAlignment="Center" />
                                                                    <ComboBox ItemsSource="{Binding LifeModeOptions}"
                                                                              DisplayMemberPath="Label"
                                                                              SelectedValuePath="Value"
                                                                              SelectedValue="{Binding LifeMode}"
                                                                              Margin="8,0,0,0"
                                                                              Width="180"
                                                                              SelectionChanged="SimulationLayerLifeMode_Changed" />
                                                                </StackPanel>
                                                                <StackPanel Orientation="Horizontal" Margin="0,0,12,6">
                                                                    <TextBlock Text="Binning" VerticalAlignment="Center" />
                                                                    <ComboBox ItemsSource="{Binding BinningModeOptions}"
                                                                              DisplayMemberPath="Label"
                                                                              SelectedValuePath="Value"
                                                                              SelectedValue="{Binding BinningMode}"
                                                                              Margin="8,0,0,0"
                                                                              Width="180"
                                                                              SelectionChanged="SimulationLayerBinningMode_Changed" />
                                                                </StackPanel>
                                                                <StackPanel Orientation="Horizontal" Margin="0,0,12,6">
                                                                    <TextBlock Text="Noise" VerticalAlignment="Center" />
                                                                    <Slider Minimum="0"
                                                                            Maximum="1"
                                                                            Value="{Binding InjectionNoise}"
                                                                            Width="150"
                                                                            Margin="8,0,0,0"
                                                                            ValueChanged="SimulationLayerInjectionNoise_Changed" />
                                                                </StackPanel>
                                                            </WrapPanel>
                                                        </StackPanel>

                                                        <StackPanel>
                                                            <StackPanel.Style>
                                                                <Style TargetType="StackPanel">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsPixelSortLayer}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </StackPanel.Style>

                                                            <TextBlock Text="Per-frame luminance sort inside each cell."
                                                                       Foreground="#A0A0A0"
                                                                       Margin="0,0,0,8" />

                                                            <WrapPanel>
                                                                <StackPanel Orientation="Horizontal" Margin="0,0,12,6">
                                                                    <TextBlock Text="Cell Width" VerticalAlignment="Center" />
                                                                    <Slider Minimum="1"
                                                                            Maximum="512"
                                                                            TickFrequency="1"
                                                                            IsSnapToTickEnabled="True"
                                                                            Value="{Binding PixelSortCellWidth}"
                                                                            Width="150"
                                                                            Margin="8,0,0,0"
                                                                            ValueChanged="SimulationLayerPixelSortGrid_Changed" />
                                                                    <TextBlock Text="{Binding PixelSortCellWidth}"
                                                                               Margin="8,0,0,0"
                                                                               VerticalAlignment="Center" />
                                                                </StackPanel>
                                                                <StackPanel Orientation="Horizontal" Margin="0,0,12,6">
                                                                    <TextBlock Text="Cell Height" VerticalAlignment="Center" />
                                                                    <Slider Minimum="1"
                                                                            Maximum="512"
                                                                            TickFrequency="1"
                                                                            IsSnapToTickEnabled="True"
                                                                            Value="{Binding PixelSortCellHeight}"
                                                                            Width="150"
                                                                            Margin="8,0,0,0"
                                                                            ValueChanged="SimulationLayerPixelSortGrid_Changed" />
                                                                    <TextBlock Text="{Binding PixelSortCellHeight}"
                                                                               Margin="8,0,0,0"
                                                                               VerticalAlignment="Center" />
                                                                </StackPanel>
                                                            </WrapPanel>
                                                        </StackPanel>

                                                        <GroupBox x:Name="SelectedSimulationReactiveMappingsGroupBox"
                                                                  Header="Reactive Mappings"
                                                                  Margin="0,10,0,10">
                                                            <StackPanel Margin="8">
                                                                <DockPanel LastChildFill="False"
                                                                           Margin="0,0,0,8">
                                                                    <TextBlock Text="Map audio inputs to per-layer outputs."
                                                                               Foreground="#A0A0A0"
                                                                               VerticalAlignment="Center"
                                                                               DockPanel.Dock="Left" />
                                                                    <Button x:Name="SelectedSimulationAddReactiveMappingButton"
                                                                            Content="Add Mapping"
                                                                            DockPanel.Dock="Right"
                                                                            Click="AddSimulationReactiveMapping_Click" />
                                                                </DockPanel>

                                                                <TextBlock Text="No reactive mappings on this layer."
                                                                           Foreground="#808080">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding ReactiveMappings.Count}" Value="0">
                                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>

                                                                <ItemsControl ItemsSource="{Binding ReactiveMappings}">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <Border BorderBrush="#2A2A2A"
                                                                                    BorderThickness="1"
                                                                                    CornerRadius="4"
                                                                                    Background="#141414"
                                                                                    Margin="0,0,0,8"
                                                                                    Padding="8">
                                                                                <StackPanel>
                                                                                    <DockPanel LastChildFill="False"
                                                                                               Margin="0,0,0,6">
                                                                                        <TextBlock Text="{Binding DisplayText}"
                                                                                                   FontWeight="SemiBold"
                                                                                                   VerticalAlignment="Center"
                                                                                                   DockPanel.Dock="Left" />
                                                                                        <Button Content="Remove"
                                                                                                DockPanel.Dock="Right"
                                                                                                Padding="8,2"
                                                                                                Click="RemoveSimulationReactiveMapping_Click" />
                                                                                    </DockPanel>

                                                                                    <WrapPanel>
                                                                                        <StackPanel Orientation="Horizontal"
                                                                                                    Margin="0,0,12,6">
                                                                                            <TextBlock Text="Input"
                                                                                                       VerticalAlignment="Center" />
                                                                                            <ComboBox ItemsSource="{Binding InputOptions}"
                                                                                                      DisplayMemberPath="Label"
                                                                                                      SelectedValuePath="Value"
                                                                                                      SelectedValue="{Binding Input}"
                                                                                                      Width="160"
                                                                                                      Margin="8,0,0,0"
                                                                                                      SelectionChanged="SimulationReactiveMappingSelection_Changed" />
                                                                                        </StackPanel>

                                                                                        <StackPanel Orientation="Horizontal"
                                                                                                    Margin="0,0,12,6">
                                                                                            <TextBlock Text="Output"
                                                                                                       VerticalAlignment="Center" />
                                                                                            <ComboBox ItemsSource="{Binding OutputOptions}"
                                                                                                      DisplayMemberPath="Label"
                                                                                                      SelectedValuePath="Value"
                                                                                                      SelectedValue="{Binding Output}"
                                                                                                      Width="160"
                                                                                                      Margin="8,0,0,0"
                                                                                                      SelectionChanged="SimulationReactiveMappingSelection_Changed" />
                                                                                        </StackPanel>

                                                                                        <StackPanel Orientation="Horizontal"
                                                                                                    Margin="0,0,12,6">
                                                                                            <TextBlock Text="{Binding AmountLabel}"
                                                                                                       VerticalAlignment="Center" />
                                                                                            <Slider Minimum="0"
                                                                                                    Maximum="{Binding AmountMaximum}"
                                                                                                    TickFrequency="{Binding AmountTickFrequency}"
                                                                                                    SmallChange="{Binding AmountSmallChange}"
                                                                                                    LargeChange="{Binding AmountLargeChange}"
                                                                                                    IsSnapToTickEnabled="False"
                                                                                                    Value="{Binding Amount}"
                                                                                                    Width="180"
                                                                                                    Margin="8,0,0,0"
                                                                                                    ValueChanged="SimulationReactiveMappingAmount_Changed" />
                                                                                            <TextBlock Text="{Binding AmountDisplay}"
                                                                                                       Margin="8,0,0,0"
                                                                                                       VerticalAlignment="Center" />
                                                                                        </StackPanel>

                                                                                        <StackPanel Orientation="Horizontal"
                                                                                                    Margin="0,0,12,6">
                                                                                            <TextBlock Text="Input Min"
                                                                                                       VerticalAlignment="Center" />
                                                                                            <Slider Minimum="0"
                                                                                                    Maximum="1"
                                                                                                    TickFrequency="0.05"
                                                                                                    SmallChange="0.01"
                                                                                                    LargeChange="0.05"
                                                                                                    IsSnapToTickEnabled="False"
                                                                                                    Value="{Binding ThresholdMin}"
                                                                                                    Width="120"
                                                                                                    Margin="8,0,0,0"
                                                                                                    ValueChanged="SimulationReactiveMappingThreshold_Changed" />
                                                                                            <TextBlock Text="{Binding ThresholdMinDisplay}"
                                                                                                       Margin="8,0,0,0"
                                                                                                       VerticalAlignment="Center" />
                                                                                        </StackPanel>

                                                                                        <StackPanel Orientation="Horizontal"
                                                                                                    Margin="0,0,12,6">
                                                                                            <TextBlock Text="Input Max"
                                                                                                       VerticalAlignment="Center" />
                                                                                            <Slider Minimum="0"
                                                                                                    Maximum="1"
                                                                                                    TickFrequency="0.05"
                                                                                                    SmallChange="0.01"
                                                                                                    LargeChange="0.05"
                                                                                                    IsSnapToTickEnabled="False"
                                                                                                    Value="{Binding ThresholdMax}"
                                                                                                    Width="120"
                                                                                                    Margin="8,0,0,0"
                                                                                                    ValueChanged="SimulationReactiveMappingThreshold_Changed" />
                                                                                            <TextBlock Text="{Binding ThresholdMaxDisplay}"
                                                                                                       Margin="8,0,0,0"
                                                                                                       VerticalAlignment="Center" />
                                                                                        </StackPanel>
                                                                                    </WrapPanel>
                                                                                </StackPanel>
                                                                            </Border>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </StackPanel>
                                                        </GroupBox>

                                                        <WrapPanel>
                                                            <WrapPanel.Style>
                                                                <Style TargetType="WrapPanel">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsLifeLayer}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </WrapPanel.Style>
                                                            <StackPanel Orientation="Horizontal" Margin="0,0,12,6">
                                                                <TextBlock Text="Threshold Min" VerticalAlignment="Center" />
                                                                <Slider x:Name="SelectedSimulationThresholdMinSlider"
                                                                        Minimum="0"
                                                                        Maximum="1"
                                                                        Value="{Binding ThresholdMin}"
                                                                        Width="150"
                                                                        Margin="8,0,0,0"
                                                                        ValueChanged="SimulationLayerThreshold_Changed" />
                                                            </StackPanel>
                                                            <StackPanel Orientation="Horizontal" Margin="0,0,12,6">
                                                                <TextBlock Text="Threshold Max" VerticalAlignment="Center" />
                                                                <Slider Minimum="0"
                                                                        Maximum="1"
                                                                        Value="{Binding ThresholdMax}"
                                                                        Width="150"
                                                                        Margin="8,0,0,0"
                                                                        ValueChanged="SimulationLayerThreshold_Changed" />
                                                            </StackPanel>
                                                            <CheckBox Content="Invert Threshold"
                                                                      Margin="0,0,12,6"
                                                                      IsChecked="{Binding InvertThreshold}"
                                                                      Checked="SimulationLayerInvertThreshold_Changed"
                                                                      Unchecked="SimulationLayerInvertThreshold_Changed" />
                                                        </WrapPanel>
                                                    </StackPanel>
                                                </StackPanel>
                                            </GroupBox>
                                        </StackPanel>
                                    </StackPanel>
                                </GroupBox>
                            </StackPanel>
                        </ScrollViewer>
                            </StackPanel>
                        </TabItem>
                        <TabItem Header="Simulation Layers">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="10">
                                    <TextBlock Text="Project-wide simulation controls live here. Per-group simulation stacks are edited from the Selected Layer tab when a Sim Group is selected."
                                               Foreground="#A0A0A0"
                                               Margin="0,0,0,10" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="3*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0"
                                                    Visibility="Collapsed">
                                            <WrapPanel Margin="0,0,0,8">
                                                <Button Content="Add Life Sim"
                                                        Click="AddSimulationLayerDirect_Click" />
                                                <Button Content="Add Pixel Sort Layer"
                                                        Click="AddSimulationPixelSort_Click" />
                                                <Button Content="Add Sim Group"
                                                        Click="AddSimulationGroup_Click" />
                                            </WrapPanel>

                                            <Border BorderBrush="#2A2A2A"
                                                    BorderThickness="1"
                                                    CornerRadius="4"
                                                    Padding="4"
                                                    Background="#141414">
                                                <TreeView x:Name="SimulationLayerTree"
                                                          ItemsSource="{Binding SimulationLayers}"
                                                          ItemTemplate="{StaticResource SimulationLayerTemplate}"
                                                          ItemContainerStyle="{StaticResource SimulationTreeViewItemStyle}"
                                                          Background="Transparent"
                                                          BorderThickness="0"
                                                          SelectedItemChanged="SimulationLayerTree_SelectedItemChanged" />
                                            </Border>

                                            <WrapPanel Margin="0,8,0,0">
                                                <Button Content="Move Up"
                                                        Click="MoveSimulationLayerUp_Click" />
                                                <Button Content="Move Down"
                                                        Click="MoveSimulationLayerDown_Click" />
                                                <Button Content="Remove"
                                                        Click="RemoveSimulationLayer_Click" />
                                            </WrapPanel>
                                        </StackPanel>

                                            <StackPanel Grid.Column="2">
                                                <GroupBox Header="Global Simulation Controls"
                                                      Margin="0,0,0,10">
                                                <StackPanel Margin="8">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="Height"
                                                                   Width="110"
                                                                   VerticalAlignment="Center" />
                                                        <ComboBox x:Name="SimulationHeightComboBox"
                                                                  ItemsSource="{Binding SimulationHeightOptions}"
                                                                  SelectedItem="{Binding SimulationHeight, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                  Width="90"
                                                                  Margin="8,0,0,0"
                                                                  SelectionChanged="SimulationHeight_Changed"
                                                                  DropDownClosed="SimulationHeight_DropDownClosed"
                                                                  LostFocus="SimulationDimensions_LostFocus"
                                                                  KeyDown="SimulationDimensions_KeyDown" />
                                                    </StackPanel>

                                                    <StackPanel Orientation="Horizontal"
                                                                Margin="0,8,0,0">
                                                        <TextBlock Text="Depth"
                                                                   Width="110"
                                                                   VerticalAlignment="Center" />
                                                        <TextBox Text="{Binding SimulationDepth}"
                                                                 Width="90"
                                                                 Margin="8,0,0,0"
                                                                 LostFocus="SimulationDimensions_LostFocus"
                                                                 KeyDown="SimulationDimensions_KeyDown" />
                                                    </StackPanel>

                                                    <StackPanel Orientation="Horizontal"
                                                                Margin="0,8,0,0">
                                                        <TextBlock Text="Framerate"
                                                                   Width="110"
                                                                   VerticalAlignment="Center" />
                                                        <TextBox Text="{Binding SimulationFramerate, StringFormat={}{0:0.##}}"
                                                                 Width="90"
                                                                 Margin="8,0,0,0"
                                                                 LostFocus="SimulationDimensions_LostFocus"
                                                                 KeyDown="SimulationDimensions_KeyDown" />
                                                    </StackPanel>

                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="Global Life Opacity"
                                                                   Width="110"
                                                                   VerticalAlignment="Center" />
                                                        <Slider Minimum="0"
                                                                Maximum="1"
                                                                Value="{Binding GlobalSimulationLifeOpacity}"
                                                                Width="160"
                                                                SmallChange="0.05"
                                                                LargeChange="0.1"
                                                                Margin="8,0,0,0"
                                                                ValueChanged="GlobalSimulationLifeOpacity_Changed" />
                                                        <TextBlock Text="{Binding GlobalSimulationLifeOpacity, StringFormat={}{0:P0}}"
                                                                   Margin="8,0,0,0"
                                                                   VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </GroupBox>

                                            <StackPanel DataContext="{Binding SelectedSimulationLayer}"
                                                        Visibility="Collapsed">
                                            <TextBlock Text="Select a simulation layer to edit settings."
                                                       Foreground="#A0A0A0"
                                                       Margin="0,0,0,8">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <GroupBox Header="Layer Settings">
                                                <StackPanel Margin="8">
                                                    <StackPanel.Style>
                                                        <Style TargetType="StackPanel">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </StackPanel.Style>

                                                    <TextBlock Text="Name" />
                                                    <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                             Margin="0,4,0,8"
                                                             TextChanged="SimulationLayerName_Changed" />

                                                    <CheckBox Content="Enabled"
                                                              IsChecked="{Binding Enabled}"
                                                              Margin="0,0,0,8"
                                                              Checked="SimulationLayerEnabled_Changed"
                                                              Unchecked="SimulationLayerEnabled_Changed" />

                                                    <TextBlock Text="Groups chain their children in order. The first child samples the incoming surface, and each later child samples the previous child output."
                                                               TextWrapping="Wrap"
                                                               Foreground="#A0A0A0"
                                                               Margin="0,0,0,8"
                                                               Visibility="{Binding IsGroup, Converter={StaticResource BoolToVisibility}}" />

                                                    <StackPanel>
                                                        <StackPanel.Style>
                                                            <Style TargetType="StackPanel">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsGroup}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </StackPanel.Style>

                                                    <StackPanel Orientation="Horizontal"
                                                                Margin="0,0,0,8">
                                                        <TextBlock Text="Input"
                                                                   VerticalAlignment="Center" />
                                                        <ComboBox ItemsSource="{Binding InputFunctionOptions}"
                                                                  DisplayMemberPath="Label"
                                                                  SelectedValuePath="Value"
                                                                  SelectedValue="{Binding InputFunction}"
                                                                  Margin="8,0,0,0"
                                                                  Width="180"
                                                                  SelectionChanged="SimulationLayerInputFunction_Changed" />
                                                    </StackPanel>

                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="Blend"
                                                                   VerticalAlignment="Center" />
                                                        <ComboBox ItemsSource="{Binding BlendModeOptions}"
                                                                  DisplayMemberPath="Label"
                                                                  SelectedValuePath="Value"
                                                                  SelectedValue="{Binding BlendMode}"
                                                                  Margin="8,0,0,0"
                                                                  Width="180"
                                                                  SelectionChanged="SimulationLayerBlendMode_Changed" />
                                                    </StackPanel>

                                                    <StackPanel Orientation="Horizontal"
                                                                Margin="0,8,0,0">
                                                        <TextBlock Text="Injection"
                                                                   VerticalAlignment="Center" />
                                                        <ComboBox ItemsSource="{Binding InjectionModeOptions}"
                                                                  DisplayMemberPath="Label"
                                                                  SelectedValuePath="Value"
                                                                  SelectedValue="{Binding InjectionMode}"
                                                                  Margin="8,0,0,0"
                                                                  Width="180"
                                                                  SelectionChanged="SimulationLayerInjectionMode_Changed" />
                                                    </StackPanel>

                                                    <StackPanel Orientation="Horizontal"
                                                                Margin="0,8,0,0">
                                                        <TextBlock Text="Life Opacity"
                                                                   VerticalAlignment="Center" />
                                                        <Slider Minimum="0"
                                                                Maximum="1"
                                                                Value="{Binding LifeOpacity}"
                                                                Width="160"
                                                                SmallChange="0.05"
                                                                LargeChange="0.1"
                                                                Margin="8,0,0,0"
                                                                ValueChanged="SimulationLayerLifeOpacity_Changed" />
                                                        <TextBlock Text="{Binding LifeOpacity, StringFormat={}{0:P0}}"
                                                                   Margin="8,0,0,0"
                                                                   VerticalAlignment="Center" />
                                                    </StackPanel>

                                                    <StackPanel Orientation="Horizontal"
                                                                Margin="0,8,0,0">
                                                        <TextBlock Text="Life Mode"
                                                                   VerticalAlignment="Center" />
                                                        <ComboBox ItemsSource="{Binding LifeModeOptions}"
                                                                  DisplayMemberPath="Label"
                                                                  SelectedValuePath="Value"
                                                                  SelectedValue="{Binding LifeMode}"
                                                                  Margin="8,0,0,0"
                                                                  Width="180"
                                                                  SelectionChanged="SimulationLayerLifeMode_Changed" />
                                                    </StackPanel>

                                                    <StackPanel Orientation="Horizontal"
                                                                Margin="0,8,0,0">
                                                        <TextBlock Text="Binning"
                                                                   VerticalAlignment="Center" />
                                                        <ComboBox ItemsSource="{Binding BinningModeOptions}"
                                                                  DisplayMemberPath="Label"
                                                                  SelectedValuePath="Value"
                                                                  SelectedValue="{Binding BinningMode}"
                                                                  Margin="8,0,0,0"
                                                                  Width="180"
                                                                  SelectionChanged="SimulationLayerBinningMode_Changed" />
                                                    </StackPanel>

                                                    <StackPanel Orientation="Horizontal"
                                                                Margin="0,8,0,0">
                                                        <TextBlock Text="Noise"
                                                                   VerticalAlignment="Center" />
                                                        <Slider Minimum="0"
                                                                Maximum="1"
                                                                Value="{Binding InjectionNoise}"
                                                                Width="160"
                                                                SmallChange="0.01"
                                                                LargeChange="0.1"
                                                                Margin="8,0,0,0"
                                                                ValueChanged="SimulationLayerInjectionNoise_Changed" />
                                                        <TextBlock Text="{Binding InjectionNoise, StringFormat={}{0:P0}}"
                                                                   Margin="8,0,0,0"
                                                                   VerticalAlignment="Center" />
                                                    </StackPanel>

                                                    <StackPanel Orientation="Horizontal"
                                                                Margin="0,8,0,0">
                                                        <TextBlock Text="Hue Offset"
                                                                   VerticalAlignment="Center" />
                                                        <Slider Minimum="0"
                                                                Maximum="360"
                                                                Value="{Binding RgbHueShiftDegrees}"
                                                                Width="160"
                                                                SmallChange="1"
                                                                LargeChange="15"
                                                                Margin="8,0,0,0"
                                                                ValueChanged="SimulationLayerHue_Changed" />
                                                        <TextBlock Text="{Binding RgbHueShiftDegrees, StringFormat={}{0:0.#}deg}"
                                                                   Margin="8,0,0,0"
                                                                   VerticalAlignment="Center" />
                                                    </StackPanel>

                                                    <StackPanel Orientation="Horizontal"
                                                                Margin="0,8,0,0">
                                                        <TextBlock Text="Hue Speed"
                                                                   VerticalAlignment="Center" />
                                                        <Slider Minimum="-180"
                                                                Maximum="180"
                                                                Value="{Binding RgbHueShiftSpeedDegreesPerSecond}"
                                                                Width="160"
                                                                SmallChange="1"
                                                                LargeChange="10"
                                                                Margin="8,0,0,0"
                                                                ValueChanged="SimulationLayerHue_Changed" />
                                                        <TextBlock Text="{Binding RgbHueShiftSpeedDegreesPerSecond, StringFormat={}{0:+0.#;-0.#;0}deg/s}"
                                                                   Margin="8,0,0,0"
                                                                   VerticalAlignment="Center" />
                                                    </StackPanel>

                                                    <GroupBox Header="Reactive Mappings"
                                                              Margin="0,10,0,0">
                                                        <StackPanel Margin="8">
                                                            <DockPanel LastChildFill="False"
                                                                       Margin="0,0,0,8">
                                                                <TextBlock Text="Map audio inputs to per-layer outputs."
                                                                           Foreground="#A0A0A0"
                                                                           VerticalAlignment="Center"
                                                                           DockPanel.Dock="Left" />
                                                                <Button Content="Add Mapping"
                                                                        DockPanel.Dock="Right"
                                                                        Click="AddSimulationReactiveMapping_Click" />
                                                            </DockPanel>

                                                            <TextBlock Text="No reactive mappings on this layer."
                                                                       Foreground="#808080">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding ReactiveMappings.Count}" Value="0">
                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>

                                                            <ItemsControl ItemsSource="{Binding ReactiveMappings}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Border BorderBrush="#2A2A2A"
                                                                                BorderThickness="1"
                                                                                CornerRadius="4"
                                                                                Background="#141414"
                                                                                Margin="0,0,0,8"
                                                                                Padding="8">
                                                                            <StackPanel>
                                                                                <DockPanel LastChildFill="False"
                                                                                           Margin="0,0,0,6">
                                                                                    <TextBlock Text="{Binding DisplayText}"
                                                                                               FontWeight="SemiBold"
                                                                                               VerticalAlignment="Center"
                                                                                               DockPanel.Dock="Left" />
                                                                                    <Button Content="Remove"
                                                                                            DockPanel.Dock="Right"
                                                                                            Padding="8,2"
                                                                                            Click="RemoveSimulationReactiveMapping_Click" />
                                                                                </DockPanel>

                                                                                <WrapPanel>
                                                                                    <StackPanel Orientation="Horizontal"
                                                                                                Margin="0,0,12,6">
                                                                                        <TextBlock Text="Input"
                                                                                                   VerticalAlignment="Center" />
                                                                                        <ComboBox ItemsSource="{Binding InputOptions}"
                                                                                                  DisplayMemberPath="Label"
                                                                                                  SelectedValuePath="Value"
                                                                                                  SelectedValue="{Binding Input}"
                                                                                                  Width="160"
                                                                                                  Margin="8,0,0,0"
                                                                                                  SelectionChanged="SimulationReactiveMappingSelection_Changed" />
                                                                                    </StackPanel>

                                                                                    <StackPanel Orientation="Horizontal"
                                                                                                Margin="0,0,12,6">
                                                                                        <TextBlock Text="Output"
                                                                                                   VerticalAlignment="Center" />
                                                                                        <ComboBox ItemsSource="{Binding OutputOptions}"
                                                                                                  DisplayMemberPath="Label"
                                                                                                  SelectedValuePath="Value"
                                                                                                  SelectedValue="{Binding Output}"
                                                                                                  Width="160"
                                                                                                  Margin="8,0,0,0"
                                                                                                  SelectionChanged="SimulationReactiveMappingSelection_Changed" />
                                                                                    </StackPanel>

                                                                                    <StackPanel Orientation="Horizontal"
                                                                                                Margin="0,0,12,6">
                                                                                        <TextBlock Text="{Binding AmountLabel}"
                                                                                                   VerticalAlignment="Center" />
                                                                                        <Slider Minimum="0"
                                                                                                Maximum="{Binding AmountMaximum}"
                                                                                                TickFrequency="{Binding AmountTickFrequency}"
                                                                                                SmallChange="{Binding AmountSmallChange}"
                                                                                                LargeChange="{Binding AmountLargeChange}"
                                                                                                IsSnapToTickEnabled="False"
                                                                                                Value="{Binding Amount}"
                                                                                                Width="180"
                                                                                                Margin="8,0,0,0"
                                                                                                ValueChanged="SimulationReactiveMappingAmount_Changed" />
                                                                                        <TextBlock Text="{Binding AmountDisplay}"
                                                                                                   Margin="8,0,0,0"
                                                                                                   VerticalAlignment="Center" />
                                                                                    </StackPanel>

                                                                                    <StackPanel Orientation="Horizontal"
                                                                                                Margin="0,0,12,6">
                                                                                        <TextBlock Text="Input Min"
                                                                                                   VerticalAlignment="Center" />
                                                                                        <Slider Minimum="0"
                                                                                                Maximum="1"
                                                                                                TickFrequency="0.05"
                                                                                                SmallChange="0.01"
                                                                                                LargeChange="0.05"
                                                                                                IsSnapToTickEnabled="False"
                                                                                                Value="{Binding ThresholdMin}"
                                                                                                Width="120"
                                                                                                Margin="8,0,0,0"
                                                                                                ValueChanged="SimulationReactiveMappingThreshold_Changed" />
                                                                                        <TextBlock Text="{Binding ThresholdMinDisplay}"
                                                                                                   Margin="8,0,0,0"
                                                                                                   VerticalAlignment="Center" />
                                                                                    </StackPanel>

                                                                                    <StackPanel Orientation="Horizontal"
                                                                                                Margin="0,0,12,6">
                                                                                        <TextBlock Text="Input Max"
                                                                                                   VerticalAlignment="Center" />
                                                                                        <Slider Minimum="0"
                                                                                                Maximum="1"
                                                                                                TickFrequency="0.05"
                                                                                                SmallChange="0.01"
                                                                                                LargeChange="0.05"
                                                                                                IsSnapToTickEnabled="False"
                                                                                                Value="{Binding ThresholdMax}"
                                                                                                Width="120"
                                                                                                Margin="8,0,0,0"
                                                                                                ValueChanged="SimulationReactiveMappingThreshold_Changed" />
                                                                                        <TextBlock Text="{Binding ThresholdMaxDisplay}"
                                                                                                   Margin="8,0,0,0"
                                                                                                   VerticalAlignment="Center" />
                                                                                    </StackPanel>
                                                                                </WrapPanel>
                                                                            </StackPanel>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                    </GroupBox>

                                                    <StackPanel Orientation="Horizontal"
                                                                Margin="0,8,0,0">
                                                        <TextBlock Text="Threshold Min"
                                                                   VerticalAlignment="Center" />
                                                        <Slider Minimum="0"
                                                                Maximum="1"
                                                                Value="{Binding ThresholdMin}"
                                                                Width="160"
                                                                SmallChange="0.01"
                                                                LargeChange="0.05"
                                                                Margin="8,0,0,0"
                                                                ValueChanged="SimulationLayerThreshold_Changed" />
                                                        <TextBlock Text="{Binding ThresholdMin, StringFormat={}{0:P0}}"
                                                                   Margin="8,0,0,0"
                                                                   VerticalAlignment="Center" />
                                                    </StackPanel>

                                                    <StackPanel Orientation="Horizontal"
                                                                Margin="0,6,0,0">
                                                        <TextBlock Text="Threshold Max"
                                                                   VerticalAlignment="Center" />
                                                        <Slider Minimum="0"
                                                                Maximum="1"
                                                                Value="{Binding ThresholdMax}"
                                                                Width="160"
                                                                SmallChange="0.01"
                                                                LargeChange="0.05"
                                                                Margin="8,0,0,0"
                                                                ValueChanged="SimulationLayerThreshold_Changed" />
                                                        <TextBlock Text="{Binding ThresholdMax, StringFormat={}{0:P0}}"
                                                                   Margin="8,0,0,0"
                                                                   VerticalAlignment="Center" />
                                                    </StackPanel>

                                                    <CheckBox Content="Invert Threshold Window"
                                                              IsChecked="{Binding InvertThreshold}"
                                                              Margin="0,8,0,0"
                                                              Checked="SimulationLayerInvertThreshold_Changed"
                                                              Unchecked="SimulationLayerInvertThreshold_Changed" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </GroupBox>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
